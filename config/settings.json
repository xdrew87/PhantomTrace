    "email_intel": {"enabled": true, "timeout": 10},
    "ip_lookup": {"enabled": true, "timeout": 10},
    "phone_lookup": {"enabled": true, "timeout": 10},
    "domain_lookup": {"enabled": true, "timeout": 15},
